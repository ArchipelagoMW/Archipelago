<WorldButton>:
    size_hint_x: None
    width: "150dp"
    theme_width: "Custom"
    radius: ["5dp", "5dp", "5dp", "5dp"]

<WorldRowStarButton>:
    size_hint_x: None
    size_hint_y: None
    theme_text_color: "Custom"
    theme_width: "Custom"
    theme_height: "Custom"
    width: "20dp"
    height: "36dp"

<BorderedBoxLayout>:
    canvas.before:
        Color:
            rgba: (app.theme_cls.primaryColor[0], app.theme_cls.primaryColor[1], app.theme_cls.primaryColor[2], 0.35)
        RoundedRectangle:
            pos: self.x, self.y
            size: self.width, self.height
            radius: [(self.height/2, self.height/2), (self.height/2, self.height/2), (self.height/2, self.height/2), (self.height/2, self.height/2)]

<OptionRow>:
    orientation: "vertical"
    size_hint_y: None
    padding: [0, 0, "5dp", "5dp"]
    MDBoxLayout:
        id: label_box
        orientation: "horizontal"
        MDAnchorLayout:
            id: label_anchor
            anchor_x: "right"
            anchor_y: "center"
    MDBoxLayout:
        id: option_widget_container
        orientation: "vertical"

<VisualRange>:
    id: this
    spacing: 15
    orientation: "horizontal"
    slider: slider
    tag: tag
    MDLabel:
        id: tag
        text: str(this.option.default) if not isinstance(this.option.default, str) else str(this.option.range_start)
    FixedScaleMDSlider:
        id: slider
        min: this.option.range_start
        max: this.option.range_end
        value: min(max(this.option.default, this.option.range_start), this.option.range_end) if not isinstance(this.option.default, str) else this.option.range_start
        step: 1
        step_point_size: 0
        MDSliderHandle:

        MDSliderValueLabel:

<VisualChoice>:
    id: this
    text: text
    MDButtonText:
        id: text
        text: this.option.get_option_name(this.option.default if not isinstance(this.option.default, str) else list(this.option.options.values())[0])
        theme_text_color: "Primary"

<VisualNamedRange>:
    id: this
    orientation: "horizontal"
    spacing: "10dp"
    padding: (0, 0, "10dp", 0)
    choice: choice

    HoverableMDButton:
        id: choice
        text: text
        MDButtonText:
            id: text
            text: this.option.default.title() if this.option.default in this.option.special_range_names else "Custom"

<VisualFreeText>:
    multiline: False
    font_size: "15sp"
    text: self.option.default if isinstance(self.option.default, str) else ""
    theme_height: "Custom"
    height: "30dp"


<VisualTextChoice>:
    id: this
    orientation: "horizontal"
    spacing: "5dp"
    padding: (0, 0, "10dp", 0)

<VisualToggle>:
    id: this
    button: button
    HoverableMDIconButton:
        id: button
        icon: "checkbox-outline" if this.option.default else "checkbox-blank-outline"

<VisualListSetEntry@ResizableTextField>:
    height: "20dp"

<CounterItemValue>:
    height: "30dp"

<VisualListSetCounter>:
    id: this
    scrollbox: scrollbox
    add: add
    save: save
    input: input
    focus_behavior: False

    MDDialogHeadlineText:
        text: getattr(this.option, "display_name", this.name)

    MDDialogSupportingText:
        text: "Add or Remove Entries"

    MDDialogContentContainer:
        orientation: "vertical"
        spacing: 10

        MDBoxLayout:
            orientation: "horizontal"
            VisualListSetEntry:
                id: input
                height: "20dp"

            HoverableMDIconButton:
                id: add
                icon: "plus"
                theme_height: "Custom"
                height: "20dp"
                on_press: root.validate_add(input)

        ScrollBox:
            id: scrollbox
            size_hint_y: None
            adapt_minimum: False

        HoverableMDButton:
            id: save
            MDButtonText:
                text: "Save Changes"

#:import ScreenManager kivy.uix.screenmanager.ScreenManager
#:import NoTransition kivy.uix.screenmanager.NoTransition
#:import MDScreen kivymd.uix.screen.MDScreen

ContainerLayout:
    md_bg_color: app.theme_cls.backgroundColor

    ScreenManager:
        id: screen_manager
        transition: NoTransition()

        MDScreen:
            name: "game_select"
            MDBoxLayout:
                orientation: "vertical"
                padding: 3, 5, 3, 3
                spacing: 0

                MDBoxLayout:
                    orientation: "vertical"
                    size_hint_x: 1
                    size_hint_y: None
                    height: "80dp"
                    spacing: 0
                    padding: 0, 0, 0, 0

                    MDLabel:
                        id: game_select_title
                        text: "Options Creator"
                        font_style: "Headline"
                        font_size: "24sp"
                        size_hint_x: 1
                        size_hint_y: None
                        height: self.texture_size[1] if self.texture_size else "40dp"
                        padding: "12dp", 0, 0, 0

                    MDLabel:
                        id: game_select_hint
                        text: "Click a world to get started, or import options you already have."
                        font_style: "Body"
                        theme_text_color: "Secondary"
                        size_hint_x: 1
                        size_hint_y: None
                        height: self.texture_size[1] if self.texture_size else "16dp"
                        padding: "12dp", 0, 0, 0

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: "60dp"
                    spacing: "5dp"
                    padding: 0, 0, 0, "5dp"

                    ResizableTextField:
                        id: world_search
                        multiline: False
                        size_hint_x: 1
                        padding_y: 0

                        MDTextFieldHintText:
                            text: "Search Games"

                    HoverableMDButton:
                        id: import_yaml_button
                        size_hint_x: None
                        size_hint_y: None
                        width: "120dp"
                        height: "60dp"
                        theme_width: "Custom"
                        theme_height: "Custom"
                        on_release: app.import_options(self)
                        MDButtonText:
                            text: "Import YAML"

                ScrollBox:
                    id: scrollbox

        MDScreen:
            name: "options_editor"
            MainLayout:
                id: player_layout
                rows: 2
                spacing: "20dp"
                padding: 3, 5, 3, 3

                MDBoxLayout:
                    id: player_options
                    orientation: "horizontal"
                    height: "75dp"
                    size_hint_y: None
                    padding: ["10dp", "30dp", "10dp", 0]
                    spacing: "10dp"

                    HoverableMDButton:
                        id: back_button
                        size_hint_x: None
                        theme_width: "Custom"
                        on_release:
                            app.screen_manager.current = 'game_select'
                            app.go_back_to_game_select()
                        MDButtonText:
                            text: "Back"

                    ResizableTextField:
                        id: player_name
                        multiline: False

                        MDTextFieldHintText:
                            text: "Player Name"

                        MDTextFieldMaxLengthText:
                            max_text_length: 16

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: "15dp"

                        MDLabel:
                            id: game
                            text: "Game: None"
                            pos_hint: {"center_x": 0.5, "center_y": 0.5}

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: "5dp"
                            size_hint_y: 1

                            HoverableMDButton:
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                                on_press: app.export_options(self)
                                theme_width: "Custom"
                                size_hint_y: 1
                                size_hint_x: 1

                                MDButtonText:
                                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                                    text: "Export Options"

                            HoverableMDButton:
                                id: options_dropdown_trigger
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                                theme_width: "Custom"
                                theme_bg_color: "Custom"
                                md_bg_color: app.theme_cls.surfaceContainerLowestColor
                                size_hint_y: 1
                                size_hint_x: None
                                width: "48dp"
                                on_release: app.open_options_dropdown(self)

                                MDButtonIcon:
                                    icon: "chevron-down"
                                    pos_hint: {"center_x": 0.5, "center_y": 0.5}

                MainLayout:
                    cols: 1
                    id: options
